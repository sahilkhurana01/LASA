# ============================================
# LASA Client — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Clerk Publishable Key (safe to commit — it's public)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# API URL (only needed if NOT using Vite proxy)
# VITE_API_URL=https://your-lasa-server.onrender.com/api

# WebSocket URL (only needed if NOT using default localhost)
# VITE_WS_URL=https://your-lasa-server.onrender.com
