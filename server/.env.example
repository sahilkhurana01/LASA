# ============================================
# LASA Server — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/lasa?appName=Cluster0

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Brevo Email (SMTP)
BREVO_API_KEY=xsmtpsib-your_brevo_api_key_here
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_smtp_login@smtp-brevo.com
BREVO_SENDER_EMAIL=your_email@gmail.com

# JWT Secret for Agent tokens
JWT_SECRET=your_random_jwt_secret_here

# IP Intelligence (optional — get free key at abuseipdb.com)
ABUSEIPDB_API_KEY=

# Report Scheduler (cron expressions)
REPORT_CRON_DAILY=30 2 * * *
REPORT_CRON_WEEKLY=30 2 * * 1

# App URL (for email links — set to your deployed frontend URL)
APP_URL=http://localhost:5173
